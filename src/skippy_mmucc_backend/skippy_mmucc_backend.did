type DocumentSection = record {
    id : nat64;
    manual_name : text;
    section : text;
    title : text;
    content : text;
};

service : (principal, principal) -> {
    "greet": (text) -> (text) query;

    "add_manual_section": (text, text, text, text) -> (nat64);
    "get_manual_section": (nat64) -> (opt DocumentSection) query;
    "list_sections_by_manual": (text) -> (vec DocumentSection) query;

    "login": () -> (variant { Ok : text; Err : text });
    "validate_session": (text) -> (opt principal) query;
}
